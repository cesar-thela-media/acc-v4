# ── Clerk Auth ──────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Redirect URLs registered in Clerk dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/billing

# Comma-separated emails that get admin access
CLERK_ADMIN_EMAILS=sarah@restoredfamily.com

# ── Resend Email ─────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified sending domain in Resend
RESEND_FROM_EMAIL=Austin Clinician Circle <hello@your-domain.com>

# Sarah's notification inbox
SARAH_EMAIL=sarah@restoredfamily.com

# ── Stripe Billing ───────────────────────────────────────────────────────────
# Use test keys for staging, live keys for production
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe portal redirect URLs
STRIPE_SANDBOX_SUCCESS_URL=https://your-domain.com/dashboard/billing?checkout=success
STRIPE_SANDBOX_CANCEL_URL=https://your-domain.com/join?checkout=cancelled

# ── Robolly (membership certificate PDF) ────────────────────────────────────
# https://robolly.com/docs/api-reference/ → API key + template ID
ROBOLLY_API_KEY=rok_...
ROBOLLY_TEMPLATE_ID=...

# Names of the dynamic text elements on the certificate template. Must match
# exactly what the element is named inside Robolly's template editor.
ROBOLLY_NAME_ELEMENT=Name
ROBOLLY_DATE_ELEMENT=Date

# Signature is intentionally not sent — that box is sized for a signature
# graphic and the template already prints the name/title statically below it.

# ── Database (Postgres, e.g. Railway) ───────────────────────────────────────
# Prisma schema is ready — run `npx prisma migrate deploy` once this is set.
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Calendly (1-on-1 practice coaching booking) ─────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/coaching

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
